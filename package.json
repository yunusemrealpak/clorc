  "files": [
    "dist",
    "dist/dashboard",
    "skills"
  ],
  "license": "MIT",
  "dependencies": {
    "commander": "^13.1.0",
    "ws": "^8.18.0"
  },
  "devDependencies": {
    "@types/node": "^22.13.0",
    "@types/ws": "^8.5.14",
    "tsup": "^8.4.0",
    "typescript": "^5.7.0",
    "vitest": "^3.0.0"
  }
}
