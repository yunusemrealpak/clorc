{
  "name": "clorc",
  "version": "1.0.0",
  "description": "Claude Code Autonomous Multi-Agent Orchestrator",
  "type": "module",
  "main": "dist/index.js",
  "bin": {
    "clorc": "dist/index.js"
  },
  "engines": {
    "node": ">=18"
  },
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "test": "vitest run",
    "test:watch": "vitest",
    "start": "node dist/index.js"
  },
  "keywords": [
    "claude-code",
    "multi-agent",
    "orchestration",
    "cli",
    "autonomous",
